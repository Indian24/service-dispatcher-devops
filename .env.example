# ─────────────────────────────────────────────────────────────
#  Technician Dispatch & Service Tracking System
#  Copy this file to .env and fill in your values
#  Never commit .env to version control
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development          # development | production
PORT=8080                     # Port the API server listens on

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dispatch_db

# Auth
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# Optional: set log level (trace | debug | info | warn | error)
LOG_LEVEL=info
